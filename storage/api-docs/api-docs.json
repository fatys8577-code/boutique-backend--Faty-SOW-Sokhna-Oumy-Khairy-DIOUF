{
    "openapi": "3.0.0",
    "info": {
        "title": "API Gestion de boutique",
        "description": "Documentation de l'API REST pour la gestion des categories, produits et acheteurs.",
        "version": "1.0.0"
    },
    "paths": {
        "/api/acheteurs": {
            "get": {
                "tags": [
                    "Acheteurs"
                ],
                "summary": "Lister tous les acheteurs",
                "operationId": "ceb448e7363a1b4f5c03c3887b9d3b33",
                "responses": {
                    "200": {
                        "description": "Liste des acheteurs"
                    }
                }
            },
            "post": {
                "tags": [
                    "Acheteurs"
                ],
                "summary": "Créer un acheteur",
                "operationId": "6b668a84a36dfc1380fc5739de88dcdc",
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "required": [
                                    "nom",
                                    "email"
                                ],
                                "properties": {
                                    "nom": {
                                        "type": "string",
                                        "example": "Mamadou Diop"
                                    },
                                    "email": {
                                        "type": "string",
                                        "example": "mamadou@mail.com"
                                    },
                                    "telephone": {
                                        "type": "string",
                                        "example": "771234567"
                                    }
                                },
                                "type": "object"
                            }
                        }
                    }
                },
                "responses": {
                    "201": {
                        "description": "Acheteur créé"
                    },
                    "422": {
                        "description": "Erreur de validation"
                    }
                }
            }
        },
        "/api/acheteurs/{id}": {
            "get": {
                "tags": [
                    "Acheteurs"
                ],
                "summary": "Détail d'un acheteur",
                "operationId": "0b4a046c39c051627363aa160b67ca12",
                "parameters": [
                    {
                        "name": "id",
                        "in": "path",
                        "required": true,
                        "schema": {
                            "type": "integer"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Détail de l'acheteur"
                    },
                    "404": {
                        "description": "Acheteur non trouvé"
                    }
                }
            },
            "put": {
                "tags": [
                    "Acheteurs"
                ],
                "summary": "Modifier un acheteur",
                "operationId": "1b372799133848443208a82dd0578630",
                "parameters": [
                    {
                        "name": "id",
                        "in": "path",
                        "required": true,
                        "schema": {
                            "type": "integer"
                        }
                    }
                ],
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "properties": {
                                    "nom": {
                                        "type": "string",
                                        "example": "Mamadou Diop"
                                    },
                                    "email": {
                                        "type": "string",
                                        "example": "mamadou@mail.com"
                                    },
                                    "telephone": {
                                        "type": "string",
                                        "example": "771234567"
                                    }
                                },
                                "type": "object"
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "Acheteur modifié"
                    },
                    "422": {
                        "description": "Erreur de validation"
                    }
                }
            },
            "delete": {
                "tags": [
                    "Acheteurs"
                ],
                "summary": "Supprimer un acheteur",
                "operationId": "f262f81ec228e6afdb8bdaf1be2bd827",
                "parameters": [
                    {
                        "name": "id",
                        "in": "path",
                        "required": true,
                        "schema": {
                            "type": "integer"
                        }
                    }
                ],
                "responses": {
                    "204": {
                        "description": "Acheteur supprimé"
                    }
                }
            }
        },
        "/api/acheteurs/{id}/acheter": {
            "post": {
                "tags": [
                    "Acheteurs"
                ],
                "summary": "Enregistrer un achat",
                "operationId": "854d078e310f389e27dc8905decc67e7",
                "parameters": [
                    {
                        "name": "id",
                        "in": "path",
                        "required": true,
                        "schema": {
                            "type": "integer"
                        }
                    }
                ],
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "required": [
                                    "produit_id",
                                    "quantite"
                                ],
                                "properties": {
                                    "produit_id": {
                                        "type": "integer",
                                        "example": 1
                                    },
                                    "quantite": {
                                        "type": "integer",
                                        "example": 2
                                    },
                                    "date_achat": {
                                        "type": "string",
                                        "format": "date",
                                        "example": "2026-07-11"
                                    }
                                },
                                "type": "object"
                            }
                        }
                    }
                },
                "responses": {
                    "201": {
                        "description": "Achat enregistré"
                    },
                    "422": {
                        "description": "Stock insuffisant ou erreur de validation"
                    }
                }
            }
        },
