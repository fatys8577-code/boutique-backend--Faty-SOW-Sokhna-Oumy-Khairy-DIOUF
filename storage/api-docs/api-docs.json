        "/api/produits": {
            "get": {
                "tags": [
                    "Produits"
                ],
                "summary": "Lister tous les produits",
                "operationId": "c7e27af70c1d33e37f767417e0880e68",
                "responses": {
                    "200": {
                        "description": "Liste des produits"
                    }
                }
            },
            "post": {
                "tags": [
                    "Produits"
                ],
                "summary": "Créer un produit",
                "operationId": "1dcf5bbc5058dd5e52384c289a96ba68",
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "required": [
                                    "nom",
                                    "prix",
                                    "stock",
                                    "categorie_id"
                                ],
                                "properties": {
                                    "nom": {
                                        "type": "string",
                                        "example": "Clavier mécanique"
                                    },
                                    "prix": {
                                        "type": "number",
                                        "format": "float",
                                        "example": 49.99
                                    },
                                    "stock": {
                                        "type": "integer",
                                        "example": 25
                                    },
                                    "description": {
                                        "type": "string",
                                        "example": "Clavier rétroéclairé"
                                    },
                                    "categorie_id": {
                                        "type": "integer",
                                        "example": 1
                                    }
                                },
                                "type": "object"
                            }
                        }
                    }
                },
                "responses": {
                    "201": {
                        "description": "Produit créé"
                    },
                    "422": {
                        "description": "Erreur de validation"
                    }
                }
            }
        },
